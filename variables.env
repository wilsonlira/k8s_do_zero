#!/bin/bash
# =============================================================================
# Kubernetes Lab - Centralized Configuration Variables
# =============================================================================
# This file contains all configurable parameters for the Kubernetes lab.
# Source this file in scripts: source ./variables.env
# =============================================================================

# -----------------------------------------------------------------------------
# AWS Configuration
# -----------------------------------------------------------------------------
AWS_REGION="us-east-1"
INSTANCE_TYPE="t2.micro"
AMI_ID="ami-0c7217cdde317cfec"  # Ubuntu 22.04 LTS us-east-1
KEY_NAME="k8s-lab-key"

# -----------------------------------------------------------------------------
# Network Configuration
# -----------------------------------------------------------------------------
VPC_CIDR="10.0.0.0/16"
SUBNET_CIDR="10.0.1.0/24"
POD_CIDR="10.244.0.0/16"
SERVICE_CIDR="10.96.0.0/12"
CLUSTER_DNS="10.96.0.10"

# -----------------------------------------------------------------------------
# Kubernetes Component Versions
# -----------------------------------------------------------------------------
K8S_VERSION="1.29.0"
ETCD_VERSION="3.5.11"
CONTAINERD_VERSION="1.7.13"
CNI_PLUGINS_VERSION="1.4.0"
COREDNS_VERSION="1.11.1"

# -----------------------------------------------------------------------------
# Node Configuration
# -----------------------------------------------------------------------------
CONTROL_PLANE_NAME="k8s-control-plane"
WORKER_NODE_NAME="k8s-worker-01"
CONTROL_PLANE_IP=""  # Populated after instance creation
WORKER_NODE_IP=""    # Populated after instance creation

# -----------------------------------------------------------------------------
# EBS Storage Configuration (Free Tier: max 30GB gp2/gp3 total)
# -----------------------------------------------------------------------------
CONTROL_PLANE_DISK_SIZE="15"  # GB
WORKER_NODE_DISK_SIZE="15"    # GB
EBS_VOLUME_TYPE="gp3"

# -----------------------------------------------------------------------------
# Certificate Configuration
# -----------------------------------------------------------------------------
CERT_VALIDITY_DAYS="3650"
CA_KEY_SIZE="2048"
CERT_DIR="/etc/kubernetes/pki"

# -----------------------------------------------------------------------------
# Cluster Configuration
# -----------------------------------------------------------------------------
CLUSTER_NAME="k8s-lab"
KUBERNETES_API_PORT="6443"
ETCD_CLIENT_PORT="2379"
ETCD_PEER_PORT="2380"
